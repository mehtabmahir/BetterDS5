<Window x:Class="BetterDS5.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BetterDS5"
        Height="760"
        Width="1180"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#111111" Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.3*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#1E1E1E"
                CornerRadius="16"
                Padding="20"
                Margin="0,0,20,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Controller Preview"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0,0,0,20" />

                <Canvas Grid.Row="1" Width="780" Height="620">

                    <!-- Touchpad -->
                    <Border x:Name="TouchpadIndicator"
                            Canvas.Left="280"
                            Canvas.Top="70"
                            Width="220"
                            Height="90"
                            CornerRadius="18"
                            Background="#2A2A2A"
                            BorderBrush="#555555"
                            BorderThickness="3"/>

                    <TextBlock Canvas.Left="350"
                               Canvas.Top="100"
                               Text="Touchpad"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <!-- Create / Options -->
                    <Ellipse x:Name="CreateIndicator"
                             Canvas.Left="250"
                             Canvas.Top="190"
                             Width="42"
                             Height="42"
                             Fill="#2A2A2A"
                             Stroke="#666666"
                             StrokeThickness="3"/>
                    <TextBlock Canvas.Left="262"
                               Canvas.Top="198"
                               Text="≡"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"/>

                    <Ellipse x:Name="OptionsIndicator"
                             Canvas.Left="488"
                             Canvas.Top="190"
                             Width="42"
                             Height="42"
                             Fill="#2A2A2A"
                             Stroke="#666666"
                             StrokeThickness="3"/>
                    <TextBlock Canvas.Left="500"
                               Canvas.Top="198"
                               Text="☰"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"/>

                    <!-- PS / Mute -->
                    <Ellipse x:Name="PSIndicator"
                             Canvas.Left="356"
                             Canvas.Top="198"
                             Width="34"
                             Height="34"
                             Fill="#2A2A2A"
                             Stroke="#666666"
                             StrokeThickness="3"/>
                    <TextBlock Canvas.Left="366"
                               Canvas.Top="204"
                               Text="P"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="Bold"/>

                    <Ellipse x:Name="MuteIndicator"
                             Canvas.Left="402"
                             Canvas.Top="198"
                             Width="34"
                             Height="34"
                             Fill="#2A2A2A"
                             Stroke="#666666"
                             StrokeThickness="3"/>
                    <TextBlock Canvas.Left="410"
                               Canvas.Top="204"
                               Text="M"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="Bold"/>

                    <!-- Shoulder / trigger buttons -->
                    <Border x:Name="L1Indicator"
                            Canvas.Left="115"
                            Canvas.Top="20"
                            Width="120"
                            Height="36"
                            CornerRadius="10"
                            Background="#2A2A2A"
                            BorderBrush="#666666"
                            BorderThickness="3"/>
                    <TextBlock Canvas.Left="157"
                               Canvas.Top="27"
                               Text="L1"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"/>

                    <Border x:Name="R1Indicator"
                            Canvas.Left="545"
                            Canvas.Top="20"
                            Width="120"
                            Height="36"
                            CornerRadius="10"
                            Background="#2A2A2A"
                            BorderBrush="#666666"
                            BorderThickness="3"/>
                    <TextBlock Canvas.Left="587"
                               Canvas.Top="27"
                               Text="R1"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"/>

                    <Border x:Name="L2ButtonIndicator"
                            Canvas.Left="115"
                            Canvas.Top="65"
                            Width="120"
                            Height="36"
                            CornerRadius="10"
                            Background="#2A2A2A"
                            BorderBrush="#666666"
                            BorderThickness="3"/>
                    <TextBlock Canvas.Left="157"
                               Canvas.Top="72"
                               Text="L2"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"/>

                    <Border x:Name="R2ButtonIndicator"
                            Canvas.Left="545"
                            Canvas.Top="65"
                            Width="120"
                            Height="36"
                            CornerRadius="10"
                            Background="#2A2A2A"
                            BorderBrush="#666666"
                            BorderThickness="3"/>
                    <TextBlock Canvas.Left="587"
                               Canvas.Top="72"
                               Text="R2"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"/>

                    <!-- D-pad -->
                    <Ellipse x:Name="DpadUpIndicator"
                             Canvas.Left="104"
                             Canvas.Top="274"
                             Width="50"
                             Height="50"
                             Fill="#2A2A2A"
                             Stroke="#666666"
                             StrokeThickness="3"/>
                    <TextBlock Canvas.Left="122"
                               Canvas.Top="286"
                               Text="↑"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"/>

                    <Ellipse x:Name="DpadLeftIndicator"
                             Canvas.Left="52"
                             Canvas.Top="326"
                             Width="50"
                             Height="50"
                             Fill="#2A2A2A"
                             Stroke="#666666"
                             StrokeThickness="3"/>
                    <TextBlock Canvas.Left="69"
                               Canvas.Top="338"
                               Text="←"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"/>

                    <Ellipse x:Name="DpadDownIndicator"
                             Canvas.Left="104"
                             Canvas.Top="378"
                             Width="50"
                             Height="50"
                             Fill="#2A2A2A"
                             Stroke="#666666"
                             StrokeThickness="3"/>
                    <TextBlock Canvas.Left="122"
                               Canvas.Top="390"
                               Text="↓"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"/>

                    <Ellipse x:Name="DpadRightIndicator"
                             Canvas.Left="156"
                             Canvas.Top="326"
                             Width="50"
                             Height="50"
                             Fill="#2A2A2A"
                             Stroke="#666666"
                             StrokeThickness="3"/>
                    <TextBlock Canvas.Left="173"
                               Canvas.Top="338"
                               Text="→"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"/>

                    <!-- Left stick -->
                    <Ellipse Canvas.Left="150"
                             Canvas.Top="440"
                             Width="140"
                             Height="140"
                             Fill="#2A2A2A"
                             Stroke="#444444"
                             StrokeThickness="3"/>
                    <Ellipse x:Name="LeftStickDot"
                             Canvas.Left="205"
                             Canvas.Top="495"
                             Width="30"
                             Height="30"
                             Fill="#4CC2FF"/>
                    <TextBlock Canvas.Left="178"
                               Canvas.Top="590"
                               Text="Left Stick"
                               Foreground="White"
                               FontSize="16"/>

                    <!-- L3 -->
                    <Ellipse x:Name="L3Indicator"
                             Canvas.Left="225"
                             Canvas.Top="328"
                             Width="44"
                             Height="44"
                             Fill="#2A2A2A"
                             Stroke="#666666"
                             StrokeThickness="3"/>
                    <TextBlock Canvas.Left="237"
                               Canvas.Top="337"
                               Text="L3"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="Bold"/>

                    <!-- Right stick -->
                    <Ellipse Canvas.Left="500"
                             Canvas.Top="440"
                             Width="140"
                             Height="140"
                             Fill="#2A2A2A"
                             Stroke="#444444"
                             StrokeThickness="3"/>
                    <Ellipse x:Name="RightStickDot"
                             Canvas.Left="555"
                             Canvas.Top="495"
                             Width="30"
                             Height="30"
                             Fill="#4CC2FF"/>
                    <TextBlock Canvas.Left="524"
                               Canvas.Top="590"
                               Text="Right Stick"
                               Foreground="White"
                               FontSize="16"/>

                    <!-- R3 -->
                    <Ellipse x:Name="R3Indicator"
                             Canvas.Left="500"
                             Canvas.Top="328"
                             Width="44"
                             Height="44"
                             Fill="#2A2A2A"
                             Stroke="#666666"
                             StrokeThickness="3"/>
                    <TextBlock Canvas.Left="512"
                               Canvas.Top="337"
                               Text="R3"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="Bold"/>

                    <!-- Face buttons -->
                    <Ellipse x:Name="TriangleIndicator"
                             Canvas.Left="634"
                             Canvas.Top="250"
                             Width="54"
                             Height="54"
                             Fill="#2A2A2A"
                             Stroke="#666666"
                             StrokeThickness="3"/>
                    <TextBlock Canvas.Left="652"
                               Canvas.Top="262"
                               Text="△"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"/>

                    <Ellipse x:Name="SquareIndicator"
                             Canvas.Left="578"
                             Canvas.Top="306"
                             Width="54"
                             Height="54"
                             Fill="#2A2A2A"
                             Stroke="#666666"
                             StrokeThickness="3"/>
                    <TextBlock Canvas.Left="596"
                               Canvas.Top="318"
                               Text="□"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"/>

                    <Ellipse x:Name="CircleIndicator"
                             Canvas.Left="690"
                             Canvas.Top="306"
                             Width="54"
                             Height="54"
                             Fill="#2A2A2A"
                             Stroke="#666666"
                             StrokeThickness="3"/>
                    <TextBlock Canvas.Left="708"
                               Canvas.Top="318"
                               Text="○"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"/>

                    <Ellipse x:Name="CrossIndicator"
                             Canvas.Left="634"
                             Canvas.Top="362"
                             Width="54"
                             Height="54"
                             Fill="#2A2A2A"
                             Stroke="#666666"
                             StrokeThickness="3"/>
                    <TextBlock Canvas.Left="652"
                               Canvas.Top="374"
                               Text="X"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"/>
                </Canvas>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Background="#1E1E1E"
                CornerRadius="16"
                Padding="20">
            <StackPanel>
                <TextBlock Text="Input Data"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <TextBlock x:Name="LXText" Text="LX: 128" Foreground="White" FontSize="18" Margin="0,0,0,8"/>
                <TextBlock x:Name="LYText" Text="LY: 128" Foreground="White" FontSize="18" Margin="0,0,0,8"/>
                <TextBlock x:Name="RXText" Text="RX: 128" Foreground="White" FontSize="18" Margin="0,0,0,8"/>
                <TextBlock x:Name="RYText" Text="RY: 128" Foreground="White" FontSize="18" Margin="0,0,0,8"/>
                <TextBlock x:Name="L2Text" Text="L2: 0" Foreground="White" FontSize="18" Margin="0,0,0,8"/>
                <TextBlock x:Name="R2Text" Text="R2: 0" Foreground="White" FontSize="18" Margin="0,0,0,18"/>

                <TextBlock x:Name="DpadText" Text="DPad: -" Foreground="White" FontSize="18" Margin="0,0,0,8"/>
                <TextBlock x:Name="FaceText" Text="Face: -" Foreground="White" FontSize="18" Margin="0,0,0,8"/>
                <TextBlock x:Name="ShoulderText" Text="Shoulders: -" Foreground="White" FontSize="18" Margin="0,0,0,8"/>
                <TextBlock x:Name="MiddleText" Text="Middle: -" Foreground="White" FontSize="18" Margin="0,0,0,8"/>
                <TextBlock x:Name="SystemText" Text="System: -" Foreground="White" FontSize="18" Margin="0,0,0,8"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>